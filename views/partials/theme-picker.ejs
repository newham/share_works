<div class="theme-picker" id="themePicker">
  <button class="theme-picker-btn" id="themeBtn" type="button" aria-haspopup="true" aria-expanded="false">
    <span class="theme-swatch" id="currentSwatch"></span>
    <span id="currentThemeName">紫色</span>
    <span style="font-size:.7rem;opacity:.5;">▼</span>
  </button>
  <div class="theme-dropdown" id="themeDropdown">
    <button class="theme-option" data-theme=""        data-name="紫色"><span class="theme-dot" style="background:#6366f1"></span>紫色</button>
    <button class="theme-option" data-theme="sky"     data-name="天蓝"><span class="theme-dot" style="background:#0ea5e9"></span>天蓝</button>
    <button class="theme-option" data-theme="emerald" data-name="翠绿"><span class="theme-dot" style="background:#10b981"></span>翠绿</button>
    <button class="theme-option" data-theme="rose"    data-name="玫瑰"><span class="theme-dot" style="background:#f43f5e"></span>玫瑰</button>
    <button class="theme-option" data-theme="orange"  data-name="橙色"><span class="theme-dot" style="background:#f97316"></span>橙色</button>
    <button class="theme-option" data-theme="amber"   data-name="金黄"><span class="theme-dot" style="background:#f59e0b"></span>金黄</button>
    <button class="theme-option" data-theme="teal"    data-name="青色"><span class="theme-dot" style="background:#14b8a6"></span>青色</button>
    <button class="theme-option" data-theme="indigo"  data-name="靛蓝"><span class="theme-dot" style="background:#4338ca"></span>靛蓝</button>
    <button class="theme-option" data-theme="fuchsia" data-name="品红"><span class="theme-dot" style="background:#d946ef"></span>品红</button>
    <button class="theme-option" data-theme="slate"   data-name="石板灰"><span class="theme-dot" style="background:#475569"></span>石板灰</button>
    <button class="theme-option" data-theme="brown"   data-name="深棕"><span class="theme-dot" style="background:#92400e"></span>深棕</button>
  </div>
</div>
<script src="/js/theme.js"></script>
