<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>管理员登录 - Share Works</title>
  <link rel="stylesheet" href="/css/style.css">
  <script>
    (function(){ var t = localStorage.getItem('sw-theme'); if(t) document.documentElement.setAttribute('data-theme', t); })();
  </script>
</head>
<body class="auth-page">
  <!-- 动效背景 -->
  <div class="bg-canvas" aria-hidden="true">
    <div class="bg-shape shape-1"></div>
    <div class="bg-shape shape-2"></div>
    <div class="bg-shape shape-3"></div>
    <div class="bg-shape shape-4"></div>
    <div class="bg-shape shape-5"></div>
    <div class="bg-shape shape-6"></div>
    <div class="bg-grid"></div>
  </div>

  <div class="auth-container">
    <div class="auth-card">
      <div class="auth-logo">🔐</div>
      <h1 class="auth-title">管理员登录</h1>
      <p class="auth-sub">请输入后台密钥进入管理面板</p>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form action="/admin" method="POST" class="auth-form">
        <div class="form-group">
          <label for="token">后台密钥</label>
          <input
            type="password"
            id="token"
            name="token"
            placeholder="输入管理员密钥"
            autofocus
            required
          >
        </div>
        <button type="submit" class="btn btn-primary btn-full">进入管理后台 →</button>
      </form>

      <a href="/" class="auth-guest-link">← 返回主页</a>
    </div>
  </div>
</body>
</html>
