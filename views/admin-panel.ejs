<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>管理后台 - Share Works</title>
  <link rel="stylesheet" href="/css/style.css">
  <script>
    (function(){ var t = localStorage.getItem('sw-theme'); if(t) document.documentElement.setAttribute('data-theme', t); })();
  </script>
</head>
<body>
  <!-- 移动端抽屉 -->
  <div class="nav-overlay" id="navOverlay"></div>
  <nav class="nav-drawer" id="navDrawer">
    <div class="nav-drawer-header">
      <span class="nav-drawer-title">菜单</span>
      <button class="nav-drawer-close" id="navCloseBtn" aria-label="关闭">✕</button>
    </div>
    <div class="nav-drawer-content">
      <a href="/" class="nav-link">🏠 返回主页</a>
      <a href="/stats" class="nav-link">📊 人气统计</a>
      <div class="drawer-divider"></div>
      <form action="/admin/logout" method="POST">
        <button type="submit" class="btn-logout btn-full">退出管理后台</button>
      </form>
      <div class="drawer-divider"></div>
      <div class="drawer-section-label">🎨 主题颜色</div>
      <div class="drawer-themes" id="drawerThemes"></div>
    </div>
  </nav>

  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo">
        <span class="logo-icon">🔐</span>
        <span class="logo-text">管理后台</span>
      </a>
      <button class="hamburger" id="hamburgerBtn" aria-label="菜单">
        <span></span><span></span><span></span>
      </button>
      <nav class="nav nav-desktop">
        <a href="/" class="nav-link">← 返回主页</a>
        <a href="/stats" class="nav-link">📊 统计</a>
        <form action="/admin/logout" method="POST" style="display:inline">
          <button type="submit" class="btn-logout">退出</button>
        </form>
      </nav>
    </div>
  </header>

  <main class="main-content admin-page">
    <h2 class="page-title">🔐 管理后台</h2>
    <p class="page-sub">此页面可删除任意用户发布的作品，请谨慎操作。</p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="works-grid">
      <% works.forEach(work => { %>
        <div class="work-card">
          <div class="card-info">
            <h3 class="card-title"><%= work.title %></h3>
            <% if (work.desc) { %>
              <p class="card-desc"><%= work.desc %></p>
            <% } %>
            <div class="card-meta">
              <span class="card-author">👤 <%= work.username %></span>
              <span class="card-date"><%= new Date(work.uploadedAt).toLocaleDateString('zh-CN') %></span>
            </div>
            <form action="/admin/delete/<%= encodeURIComponent(work.filename) %>" method="POST"
                  onsubmit="return confirm('确认删除「<%= work.title %>」？此操作不可撤销。')">
              <button type="submit" class="btn-delete" style="margin-top:10px; background:#fee2e2; border-color:#fca5a5; color:#b91c1c;">
                🗑 删除此作品
              </button>
            </form>
          </div>
        </div>
      <% }); %>
    </div>

    <% if (works.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">✅</div>
        <p>暂无作品，很干净！</p>
      </div>
    <% } %>
  </main>

  <script src="/js/mobile-nav.js"></script>
</body>
</html>
